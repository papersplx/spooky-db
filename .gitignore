# Downloads and Wine prefix
downloads/
wine_spooky/
*.zip
*.exe

# Node modules
node_modules/

# Environment files
*.env.local
.env.local
.envrc

# Build artifacts
dist/
build/

# Large data files (use git-lfs or external storage)
data/presets/presets_all.json
data/presets/by_collection/
spooky2-search/public/data/

# Generated extraction stats (recreated on each run)
data/presets/extraction_stats.json

# Telegram raw presets: ignore large binaries, keep small metadata
data/presets/telegram_raw/*
!data/presets/telegram_raw/telegram_group_timestamps.json
!data/presets/telegram_raw/postprocess_manifest.json
!data/presets/telegram_raw/Spooky2_PROVEN_FILES/postprocess_manifest.json
!data/presets/telegram_raw/Spooky2_Unproven/postprocess_manifest.json

# Backups (can be large)
data/presets/backups/

# Logs and temp files
*.log
*.tmp
__pycache__/
.pytest_cache/

# Kilo AI agent files
.kilo/

# Telegram scraper session (private - keep out of git)
telegram_scraper_session.*
telegram_config.env
scripts/telegram_scraper_session.*

# Large Telegram archive containers (exceed GitHub limits)
*.zip.txt
