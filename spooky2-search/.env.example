# Vite environment variables for Spooky2 Search frontend
# Copy to .env.local for local development
#
# For local dev (npm run dev):
#   API requests are proxied through Vite to avoid CORS issues
VITE_API_BASE=/api

# For production (npm run build):
#   Leave VITE_API_BASE empty to use relative paths (same origin)
# VITE_API_BASE=