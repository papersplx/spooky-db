# ============================================================
# Telegram Scraper Configuration for Spooky2 Preset Download
# ============================================================
# Copy this file to telegram_config.env and fill in your values.
#
# Authentication options (choose ONE):
#   Option A: User account (phone + code) - for private groups
#   Option B: Bot token - bot must be added to groups first
#
# Get API credentials: https://my.telegram.org
# ============================================================

# ---- Option A: User Authentication ----
# Your Telegram API credentials (from https://my.telegram.org/apps)
API_ID=12345678
API_HASH=your_api_hash_here

# Your phone number with country code (e.g., +1 for USA)
PHONE=+1234567890

# ---- Option B: Bot Authentication ----
# Uncomment and fill in instead of API_ID/API_HASH + PHONE above
# Get a bot token from @BotFather on Telegram
# BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567890

# ---- Target Groups ----
# Add Telegram group usernames, invite links, or numeric IDs
# Examples:
#   "@spooky2frequencies"          - public group by username
#   "https://t.me/+ABC123def"      - invite link
#   "-1001234567890"               - numeric group ID (negative for channels/groups)
GROUPS=["@spooky2frequencies", "@spooky2presets"]

# ---- Output Settings ----
# Where to save downloaded files (relative to scripts/ directory)
OUTPUT_DIR=../downloads/telegram_presets

# File extensions to download (presets are typically .txt)
FILE_TYPES=[".txt"]

# ---- Scraping Limits ----
# Max messages to scan per group (0 = scan everything)
MAX_MESSAGES=0

# Delay between requests to avoid rate limiting (seconds)
REQUEST_DELAY=0.5

# Retry settings for failed downloads
MAX_RETRIES=3
RETRY_DELAY=5

# ---- Logging ----
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (relative to scripts/ directory)
# Set empty to disable file logging
LOG_FILE=telegram_scraper.log